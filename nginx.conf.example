# nginx.conf.example — WindFoil Weather Intelligence
# Serves the static frontend AND forwards /api/* to the Node proxy on :8787.
# This keeps everything same-origin, so the browser never sees the API key
# and there are no CORS problems.
#
# Adjust: server_name, root path, and the SSL certificate paths.

server {
    listen 80;
    server_name windfoil.example.com;
    # Redirect all HTTP to HTTPS (GPS/Geolocation requires HTTPS)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name windfoil.example.com;

    # --- SSL (e.g. from Let's Encrypt / certbot) ---
    ssl_certificate     /etc/letsencrypt/live/windfoil.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/windfoil.example.com/privkey.pem;

    # --- Static frontend ---
    # Put app-react.html (renamed to index.html) + assets here:
    root /var/www/windfoil;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # --- API proxy → Node backend (proxy-server.js on port 8787) ---
    location /api/ {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}
