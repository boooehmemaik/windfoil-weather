# windfoil.env — Konfiguration für den Proxy (NICHT in Git committen!)
# Liegt neben proxy-server.js. Wird beim Start automatisch geladen.
#
# Diese Datei steht bereits in .gitignore (.env-Muster) — trotzdem vor jedem
# Commit mit `git status` prüfen, dass sie nicht auftaucht.

# Weatherbit API-Key (für echte Stationsdaten / Vertrauens-Score)
WEATHERBIT_KEY=dein_weatherbit_key

# ── Admin-Bereich ─────────────────────────────────────────────────────────────
# ADMIN_PASSWORD: das Passwort, das du im Admin-Tab eingibst.
ADMIN_PASSWORD=nuc

# ADMIN_TOKEN: das eigentliche Geheimnis (sichert die Deploy-Befehle ab).
# UNBEDINGT durch einen langen Zufallswert ersetzen, NICHT "nuc" lassen!
# Erzeugen mit:   openssl rand -hex 24
ADMIN_TOKEN=BITTE_AENDERN_langer_zufallswert

# Projektverzeichnis (wo deploy.sh liegt)
APP_DIR=/var/www/windfoil

# Port des Proxys (Standard 8787)
PORT=8787
