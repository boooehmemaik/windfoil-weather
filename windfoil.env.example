# windfoil.env — Konfiguration für den Proxy (NICHT in Git committen!)
# Liegt neben proxy-server.js. Wird beim Start automatisch geladen.
#
# Diese Datei (windfoil.env) steht bereits in .gitignore (.env-Muster) — und
# deploy.sh verweigert den Deploy, falls sie doch ins Git gerät. Vor jedem
# Commit mit `git status` prüfen, dass sie NICHT auftaucht.
#
# Einrichten:  cp windfoil.env.example windfoil.env  und unten die Werte setzen.

# ── Wetterdaten ───────────────────────────────────────────────────────────────
# Weatherbit API-Key (für echte Stationsdaten / Vertrauens-Score)
WEATHERBIT_KEY=dein_weatherbit_key

# ── Better Auth (Login / Registrierung) ──────────────────────────────────────
# Starkes Geheimnis erzeugen mit:  openssl rand -base64 32
BETTER_AUTH_SECRET=BITTE_AENDERN_openssl_rand_base64_32
# Öffentliche Basis-URL inkl. Port — MUSS exakt dem Origin im Browser
# entsprechen (sonst lehnt Better Auth Logins mit "Invalid origin" ab).
BETTER_AUTH_URL=https://deine-adresse.myfritz.net:8505

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Pfad zur SQLite-Datei (Auth + Sessions + Feedback/Spot-Kalibrierung)
WINDFOIL_DB_PATH=/var/www/windfoil/data/windfoil.db

# ── Server ────────────────────────────────────────────────────────────────────
# Interner Port des Node-Proxys (nginx leitet /api/ hierhin weiter)
PORT=8787

# ── Admin-Bereich (Deploy-Tab + Benutzerverwaltung) ──────────────────────────
# ADMIN_PASSWORD: das Passwort, das du im Admin-Tab eingibst (mind. ~10 Zeichen).
ADMIN_PASSWORD=BITTE_AENDERN_starkes_passwort
# ADMIN_TOKEN: das eigentliche Server-Geheimnis (sichert die Admin-Befehle ab,
# wird nie manuell eingegeben). Erzeugen mit:  openssl rand -hex 24
# Ohne ADMIN_PASSWORD + ADMIN_TOKEN sind alle Admin-Funktionen deaktiviert.
ADMIN_TOKEN=BITTE_AENDERN_langer_zufallswert
